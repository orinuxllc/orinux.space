---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pricing from "@/components/Pricing.astro";
import CTA from "@/components/CTA.astro";

const faqs = [
  {
    q: "Үнэгүй туршилт байгаа юу?",
    a: "Тийм, Starter тарифыг 14 хоног үнэгүй туршиж болно. Картын мэдээлэл шаардахгүй.",
  },
  {
    q: "Тариф солих боломжтой юу?",
    a: "Тийм, хэзээ ч дээш эсвэл доош тарифт шилжиж болно. Зөрүү дүнг тооцоолно.",
  },
  {
    q: "Модуль тус бүрт нэмэлт төлбөр байгаа юу?",
    a: "Үгүй, тарифынхаа хязгаар дотор хэдэн ч модуль идэвхжүүлэх боломжтой.",
  },
  {
    q: "On-premise суулгац боломжтой юу?",
    a: "Тийм, Enterprise тарифт серверт суулгах боломжтой. Бид суулгаж, тохируулж өгнө.",
  },
  {
    q: "Өгөгдөл хаана хадгалагддаг вэ?",
    a: "Өгөгдөл нь байгууллага бүрт тусдаа, Монголын серверт хадгалагдана. Экспортлох боломжтой.",
  },
  {
    q: "Техникийн дэмжлэг хэрхэн авах вэ?",
    a: "Starter: Email дэмжлэг. Business: Чат + утас. Enterprise: Dedicated менежер + SLA.",
  },
];
---

<BaseLayout title="Үнэ — orinux ARP" description="Orinux ARP тарифууд — Starter 99,000₮, Business 299,000₮, Enterprise тохиролцоно. 14 хоног үнэгүй туршилт.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.a
        }
      }))
    })} />
  </Fragment>
  <section class="pt-32">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Энгийн, ил тод үнэ</h1>
      <p class="mt-4 text-lg text-surface-300">
        Нуугдмал төлбөр байхгүй. Хэрэгтэй зүйлдээ л төлнө.
      </p>
    </div>
  </section>

  <Pricing />

  <!-- FAQ -->
  <section class="py-24">
    <div class="mx-auto max-w-3xl px-6">
      <h2 class="text-center text-3xl font-bold tracking-tight" data-reveal>Түгээмэл асуулт</h2>

      <div class="mt-12 space-y-4">
        {
          faqs.map((faq, i) => (
            <details
              class="group rounded-xl border border-white/[0.08] bg-white/[0.02] transition-colors hover:border-white/15"
              data-reveal
              data-reveal-delay={String(Math.min(i + 1, 5))}
            >
              <summary class="flex cursor-pointer items-center justify-between px-6 py-4 text-sm font-medium transition-colors hover:text-primary-400">
                {faq.q}
                <svg
                  class="h-4 w-4 shrink-0 text-surface-400 transition-transform group-open:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-4 text-sm leading-relaxed text-surface-300">{faq.a}</div>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
