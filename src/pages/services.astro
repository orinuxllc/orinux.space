---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { services, serviceProcess } from "@/data/services";
---

<BaseLayout title="Үйлчилгээ — orinux ARP" description="AI Agent суурилуулалт, RAG систем тохируулалт, бизнес процесс автоматжуулалт — Orinux-ийн мэргэжлийн үйлчилгээ.">
  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-dot-pattern opacity-30"></div>
      <div class="absolute left-1/2 top-0 h-[500px] w-[700px] -translate-x-1/2 rounded-full bg-accent-600/12 blur-[128px] animate-float-slow"></div>
      <div class="absolute left-0 top-1/3 h-[300px] w-[300px] rounded-full bg-primary-600/8 blur-[96px] animate-float"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/[0.08] px-5 py-2 shadow-lg shadow-accent-500/5" data-reveal>
          <span class="h-2 w-2 animate-pulse rounded-full bg-accent-400"></span>
          <span class="text-sm font-medium text-accent-300">Мэргэжлийн үйлчилгээ</span>
        </div>
        <h1 class="mt-6 text-4xl font-bold tracking-tight md:text-6xl" data-reveal data-reveal-delay="1">
          <span class="text-gradient-primary">AI Agent & RAG</span>
          <br />
          <span class="text-gradient-flow">Тохируулалтын Үйлчилгээ</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-surface-300 md:text-xl" data-reveal data-reveal-delay="2">
          Танай байгууллагын үйл ажиллагааг AI-ээр автоматжуулж,
          мэдлэгийн санд суурилсан ухаалаг систем бүтээж өгнө.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" data-reveal data-reveal-delay="3">
          <a href="/contact" class="btn-primary">
            Зөвлөгөө авах
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a href="#services-list" class="btn-secondary">
            Үйлчилгээ үзэх
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section id="services-list" class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Бидний үйлчилгээнүүд</h2>
        <p class="mt-4 text-lg text-surface-300">
          AI нэвтрүүлэлтийн бүх үе шатанд мэргэжлийн дэмжлэг үзүүлнэ.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service, i) => (
            <div
              class="group relative rounded-2xl border border-white/[0.08] bg-white/[0.02] p-8 hover-lift transition-all hover:border-accent-500/20 hover:bg-white/[0.04]"
              data-reveal
              data-reveal-delay={String(Math.min(i + 1, 5))}
            >
              <div class="mb-6">
                <span class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-medium text-accent-400">
                  {service.tag}
                </span>
              </div>

              <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 text-primary-400 transition-all group-hover:from-primary-500/25 group-hover:to-accent-500/25 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-primary-500/10">
                <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d={service.icon} />
                </svg>
              </div>

              <h3 class="mt-5 text-xl font-semibold tracking-tight">{service.name}</h3>
              <span class="text-xs text-surface-400">{service.nameEn}</span>
              <p class="mt-3 text-sm leading-relaxed text-surface-300">{service.desc}</p>

              <ul class="mt-6 space-y-2.5">
                {service.features.map((f) => (
                  <li class="flex items-center gap-2 text-sm text-surface-300">
                    <svg class="h-4 w-4 shrink-0 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>

              <div class="mt-8">
                <a href="/contact" class="inline-flex items-center gap-2 text-sm font-medium text-primary-400 transition-colors hover:text-primary-300">
                  Дэлгэрэнгүй
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-24 bg-white/[0.015]">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Хэрхэн ажилладаг вэ?</h2>
        <p class="mt-4 text-lg text-surface-300">Бид 4 үе шатаар таны бизнесийг AI-д шилжүүлнэ.</p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {
          serviceProcess.map((step, i) => (
            <div class="relative text-center" data-reveal data-reveal-delay={String(i + 1)}>
              {i < serviceProcess.length - 1 && (
                <div class="absolute right-0 top-10 hidden h-px w-full translate-x-1/2 bg-gradient-to-r from-accent-500/30 to-transparent lg:block" />
              )}
              <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-2xl border border-accent-500/15 bg-gradient-to-br from-accent-500/10 to-primary-500/10 shadow-lg shadow-accent-500/5 transition-all hover:scale-105 hover:shadow-accent-500/15">
                <span class="text-2xl font-bold text-gradient-accent">{step.num}</span>
              </div>
              <h3 class="mt-5 text-lg font-semibold tracking-tight">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-surface-300">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Яагаад бид гэж?</h2>
        <p class="mt-4 text-lg text-surface-300">Orinux-ийн AI мэргэжилтнүүд танд туслахад бэлэн.</p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          [
            { title: "AI-д мэргэшсэн баг", desc: "LLM, RAG, Agent framework-ийн чиглэлээр туршлагатай инженерүүд.", icon: "M12 8V4H8M12 8a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM4 12a8 8 0 0 0 16 0M9 17v1m6-1v1" },
            { title: "Монголд зориулсан", desc: "Монгол хэл, Монголын бизнесийн онцлог, дотоодын интеграцуудыг бүрэн дэмждэг.", icon: "M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0ZM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" },
            { title: "End-to-End шийдэл", desc: "Зөвлөгөөнөөс эхлээд суурилуулалт, сургалт, дэмжлэг хүртэл бүгдийг хамарна.", icon: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" },
            { title: "Аюулгүй байдал", desc: "Өгөгдлийн нууцлал, тусдаа орчин, Монголын серверт хадгалалт.", icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" },
            { title: "Хурдан хэрэгжүүлэлт", desc: "Бэлэн framework, батлагдсан процесс дээр суурилж хурдан шийдэл гаргана.", icon: "M13 2L3 14h9l-1 8 10-12h-9l1-8" },
            { title: "Тасралтгүй дэмжлэг", desc: "Суурилуулсны дараа ч тогтмол сайжруулалт, хяналт, дэмжлэг үзүүлнэ.", icon: "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8ZM22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" },
          ].map((item, i) => (
            <div
              class="group rounded-2xl border border-white/[0.08] bg-white/[0.02] p-8 hover-lift transition-all hover:border-primary-500/20 hover:bg-white/[0.04]"
              data-reveal
              data-reveal-delay={String(Math.min(i + 1, 5))}
            >
              <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 text-primary-400 transition-all group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-primary-500/10">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                  <path d={item.icon} />
                </svg>
              </div>
              <h3 class="mt-5 text-lg font-semibold tracking-tight">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-surface-300">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="relative overflow-hidden rounded-3xl border border-accent-500/15 bg-gradient-to-br from-accent-950 via-surface-900 to-primary-950 p-12 md:p-20" data-reveal>
        <div class="absolute inset-0 bg-grid-pattern opacity-15"></div>
        <div class="absolute left-1/2 top-0 -z-0 h-64 w-96 -translate-x-1/2 rounded-full bg-accent-500/20 blur-[80px] animate-glow-pulse"></div>

        <div class="relative z-10 mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight md:text-4xl">AI-ээр бизнесээ хүчирхэгжүүл</h2>
          <p class="mt-4 text-lg text-surface-300">
            Үнэгүй зөвлөгөө аваад, AI танай байгууллагад юу хийж чадахыг мэдэж аваарай.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a href="/contact" class="shine-on-hover inline-flex items-center gap-2 rounded-xl bg-white px-8 py-3.5 font-medium text-surface-900 transition-all hover:shadow-xl hover:shadow-white/10 hover:-translate-y-0.5">
              Үнэгүй зөвлөгөө авах
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="/contact" class="btn-secondary">Холбоо барих</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
