---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { services, serviceProcess } from "@/data/services";
---

<BaseLayout title="Үйлчилгээ — orinux ARP">
  <!-- Hero -->
  <section class="relative overflow-hidden pt-32 pb-20">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-0 h-[500px] w-[700px] -translate-x-1/2 rounded-full bg-accent-600/15 blur-[128px]"></div>
      <div class="absolute left-0 top-1/3 h-[300px] w-[300px] rounded-full bg-primary-600/10 blur-[96px]"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/30 bg-accent-500/10 px-4 py-1.5">
          <span class="h-2 w-2 animate-pulse rounded-full bg-accent-400"></span>
          <span class="text-sm text-accent-300">Мэргэжлийн үйлчилгээ</span>
        </div>
        <h1 class="mt-6 text-4xl font-bold md:text-6xl">
          <span class="bg-gradient-to-r from-white via-white to-surface-200 bg-clip-text text-transparent">
            AI Agent & RAG
          </span>
          <br />
          <span class="bg-gradient-to-r from-primary-400 to-accent-400 bg-clip-text text-transparent">
            Тохируулалтын Үйлчилгээ
          </span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-surface-200 md:text-xl">
          Танай байгууллагын үйл ажиллагааг AI-ээр автоматжуулж,
          мэдлэгийн санд суурилсан ухаалаг систем бүтээж өгнө.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-xl bg-primary-600 px-8 py-3.5 font-medium transition-all hover:bg-primary-500 hover:shadow-lg hover:shadow-primary-600/25"
          >
            Зөвлөгөө авах
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="#services-list"
            class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-8 py-3.5 font-medium transition-all hover:border-white/40 hover:bg-white/5"
          >
            Үйлчилгээ үзэх
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services List -->
  <section id="services-list" class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold md:text-4xl">Бидний үйлчилгээнүүд</h2>
        <p class="mt-4 text-lg text-surface-200">
          AI нэвтрүүлэлтийн бүх үе шатанд мэргэжлийн дэмжлэг үзүүлнэ.
        </p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service) => (
            <div class="group relative rounded-2xl border border-white/10 bg-white/[0.03] p-8 transition-all hover:border-accent-500/30 hover:bg-white/[0.06]">
              {/* Tag */}
              <div class="mb-6">
                <span class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-medium text-accent-400">
                  {service.tag}
                </span>
              </div>

              {/* Icon */}
              <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500/20 to-accent-500/20 text-primary-400 transition-colors group-hover:from-primary-500/30 group-hover:to-accent-500/30">
                <svg
                  class="h-7 w-7"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  viewBox="0 0 24 24"
                >
                  <path d={service.icon} />
                </svg>
              </div>

              {/* Content */}
              <h3 class="mt-5 text-xl font-semibold">{service.name}</h3>
              <span class="text-xs text-surface-300">{service.nameEn}</span>
              <p class="mt-3 text-sm leading-relaxed text-surface-200">{service.desc}</p>

              {/* Features */}
              <ul class="mt-6 space-y-2.5">
                {service.features.map((f) => (
                  <li class="flex items-center gap-2 text-sm text-surface-200">
                    <svg class="h-4 w-4 shrink-0 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>

              {/* CTA */}
              <div class="mt-8">
                <a
                  href="/contact"
                  class="inline-flex items-center gap-2 text-sm font-medium text-primary-400 transition-colors hover:text-primary-300"
                >
                  Дэлгэрэнгүй
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How We Work -->
  <section class="py-24 bg-white/[0.02]">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold md:text-4xl">Хэрхэн ажилладаг вэ?</h2>
        <p class="mt-4 text-lg text-surface-200">Бид 4 үе шатаар таны бизнесийг AI-д шилжүүлнэ.</p>
      </div>

      <div class="mt-16 grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {
          serviceProcess.map((step, i) => (
            <div class="relative text-center">
              {/* Connector */}
              {i < serviceProcess.length - 1 && (
                <div class="absolute right-0 top-10 hidden h-px w-full translate-x-1/2 bg-gradient-to-r from-accent-500/50 to-transparent lg:block" />
              )}

              <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-2xl border border-accent-500/20 bg-accent-500/10">
                <span class="text-2xl font-bold text-accent-400">{step.num}</span>
              </div>
              <h3 class="mt-5 text-lg font-semibold">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-surface-200">{step.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Why Us -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-3xl font-bold md:text-4xl">Яагаад бид гэж?</h2>
        <p class="mt-4 text-lg text-surface-200">Orinux-ийн AI мэргэжилтнүүд танд туслахад бэлэн.</p>
      </div>

      <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M12 8V4H8M12 8a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM4 12a8 8 0 0 0 16 0M9 17v1m6-1v1" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold">AI-д мэргэшсэн баг</h3>
          <p class="mt-2 text-sm leading-relaxed text-surface-200">LLM, RAG, Agent framework-ийн чиглэлээр туршлагатай инженерүүд.</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0ZM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold">Монголд зориулсан</h3>
          <p class="mt-2 text-sm leading-relaxed text-surface-200">Монгол хэл, Монголын бизнесийн онцлог, дотоодын интеграцуудыг бүрэн дэмждэг.</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold">End-to-End шийдэл</h3>
          <p class="mt-2 text-sm leading-relaxed text-surface-200">Зөвлөгөөнөөс эхлээд суурилуулалт, сургалт, дэмжлэг хүртэл бүгдийг хамарна.</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold">Аюулгүй байдал</h3>
          <p class="mt-2 text-sm leading-relaxed text-surface-200">Өгөгдлийн нууцлал, тусдаа орчин, Монголын серверт хадгалалт.</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold">Хурдан хэрэгжүүлэлт</h3>
          <p class="mt-2 text-sm leading-relaxed text-surface-200">Бэлэн framework, батлагдсан процесс дээр суурилж хурдан шийдэл гаргана.</p>
        </div>

        <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
          <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
              <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 3a4 4 0 1 0 0 8 4 4 0 0 0 0-8ZM22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold">Тасралтгүй дэмжлэг</h3>
          <p class="mt-2 text-sm leading-relaxed text-surface-200">Суурилуулсны дараа ч тогтмол сайжруулалт, хяналт, дэмжлэг үзүүлнэ.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="relative overflow-hidden rounded-3xl border border-accent-500/20 bg-gradient-to-br from-accent-950 via-surface-900 to-primary-950 p-12 md:p-20">
        <div class="absolute left-1/2 top-0 -z-0 h-64 w-96 -translate-x-1/2 rounded-full bg-accent-500/20 blur-[80px]"></div>

        <div class="relative z-10 mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold md:text-4xl">
            AI-ээр бизнесээ хүчирхэгжүүл
          </h2>
          <p class="mt-4 text-lg text-surface-200">
            Үнэгүй зөвлөгөө аваад, AI танай байгууллагад юу хийж чадахыг мэдэж аваарай.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a
              href="/contact"
              class="inline-flex items-center gap-2 rounded-xl bg-white px-8 py-3.5 font-medium text-surface-900 transition-all hover:bg-surface-100"
            >
              Үнэгүй зөвлөгөө авах
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a
              href="/pricing"
              class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-8 py-3.5 font-medium transition-all hover:border-white/40 hover:bg-white/5"
            >
              Үнэ харах
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
