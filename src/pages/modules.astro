---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { modules, categories } from "@/data/modules";
---

<BaseLayout title="Модулиуд — orinux ARP">
  <section class="pt-32 pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <!-- Header -->
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold md:text-5xl">Бүх модулиуд</h1>
        <p class="mt-4 text-lg text-surface-200">
          40+ модулиас хэрэгтэйгээ сонгоод бизнесээ тохируул.
          Модуль бүрт AI Agent суурилуулсан.
        </p>
      </div>

      <!-- Categories -->
      {
        categories.map((cat) => {
          const catModules = modules.filter((m) => m.category === cat.id);
          return (
            <div class="mt-16">
              <div class="mb-6 flex items-center gap-3">
                <h2 class="text-2xl font-bold">{cat.name}</h2>
                <span class="rounded-full bg-white/10 px-3 py-0.5 text-sm text-surface-200">
                  {catModules.length}
                </span>
              </div>

              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {catModules.map((mod) => (
                  <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-all hover:border-primary-500/20 hover:bg-white/[0.05]">
                    <div class="flex items-center gap-3">
                      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-500/10 text-xs font-bold text-primary-400">
                        {mod.nameEn.slice(0, 2).toUpperCase()}
                      </div>
                      <div>
                        <h3 class="font-semibold">{mod.name}</h3>
                        <span class="text-xs text-surface-200">{mod.nameEn}</span>
                      </div>
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-surface-200">{mod.desc}</p>
                    <div class="mt-4 flex items-center gap-2">
                      <span class="flex items-center gap-1 text-xs text-primary-400">
                        <svg
                          class="h-3 w-3"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M12 8V4H8M12 8a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z"
                          />
                        </svg>
                        AI Agent
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }

      <!-- CTA -->
      <div class="mt-20 text-center">
        <p class="text-surface-200">Өөрийн бизнест ямар модуль тохирохыг мэдэхгүй байна уу?</p>
        <a
          href="/contact"
          class="mt-4 inline-flex items-center gap-2 rounded-xl bg-primary-600 px-8 py-3 font-medium transition-colors hover:bg-primary-500"
        >
          Бидэнтэй холбогдох
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
