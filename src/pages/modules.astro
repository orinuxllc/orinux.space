---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { modules, categories } from "@/data/modules";
---

<BaseLayout title="Модулиуд — orinux ARP" description="40+ модуль — И-Худалдаа, Агуулах, Санхүү, HRM, CRM болон 20+ салбарын шийдэл. Модуль бүрт AI Agent.">
  <section class="pt-32 pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Бүх модулиуд</h1>
        <p class="mt-4 text-lg text-surface-300">
          40+ модулиас хэрэгтэйгээ сонгоод бизнесээ тохируул.
          Модуль бүрт AI Agent суурилуулсан.
        </p>
      </div>

      {
        categories.map((cat) => {
          const catModules = modules.filter((m) => m.category === cat.id);
          const isIndustry = cat.id === "industry";
          return (
            <div class="mt-16" data-reveal>
              <div class="mb-6 flex items-center gap-3">
                <h2 class="text-2xl font-bold tracking-tight">{cat.name}</h2>
                <span class:list={[
                  "rounded-full px-3 py-0.5 text-sm font-medium",
                  isIndustry ? "bg-accent-500/10 text-accent-400" : "bg-primary-500/10 text-primary-400"
                ]}>
                  {catModules.length}
                </span>
              </div>

              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                {catModules.map((mod) => (
                  <div class="group rounded-2xl border border-white/[0.08] bg-white/[0.02] p-6 hover-lift transition-all hover:border-primary-500/15 hover:bg-white/[0.04]">
                    <div class="flex items-center gap-3">
                      <div class:list={[
                        "flex h-10 w-10 items-center justify-center rounded-lg text-xs font-bold",
                        isIndustry
                          ? "bg-gradient-to-br from-accent-500/15 to-primary-500/10 text-accent-400"
                          : "bg-gradient-to-br from-primary-500/15 to-accent-500/10 text-primary-400"
                      ]}>
                        {mod.nameEn.slice(0, 2).toUpperCase()}
                      </div>
                      <div>
                        <h3 class="font-semibold">{mod.name}</h3>
                        <span class="text-xs text-surface-400">{mod.nameEn}</span>
                      </div>
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-surface-300">{mod.desc}</p>
                    <div class="mt-4 flex items-center gap-2">
                      <span class="flex items-center gap-1 text-xs text-primary-400">
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8V4H8M12 8a2 2 0 1 1 0 4 2 2 0 0 1 0-4Z" />
                        </svg>
                        AI Agent
                      </span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          );
        })
      }

      <div class="mt-20 text-center" data-reveal>
        <p class="text-surface-300">Өөрийн бизнест ямар модуль тохирохыг мэдэхгүй байна уу?</p>
        <a href="/contact" class="mt-4 btn-primary inline-flex">
          Бидэнтэй холбогдох
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
