---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.svelte";
---

<BaseLayout title="Холбоо барих — orinux ARP" description="Orinux-тэй холбогдох — демо авах, AI зөвлөгөө авах. И-мэйл: info@orinux.space, Утас: +976 6003-4140.">
  <section class="pt-32 pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center" data-reveal>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Холбоо барих</h1>
        <p class="mt-4 text-lg text-surface-300">
          Демо авах, асуулт тавих, хамтран ажиллах — бидэнтэй холбогдоорой.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl gap-12 md:grid-cols-5">
        <!-- Contact Info -->
        <div class="space-y-8 md:col-span-2" data-reveal>
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-surface-400">И-мэйл</h3>
            <a
              href="mailto:info@orinux.space"
              class="mt-2 block text-lg transition-colors hover:text-primary-400"
            >
              info@orinux.space
            </a>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-surface-400">Утас</h3>
            <a
              href="tel:+97660034140"
              class="mt-2 block text-lg transition-colors hover:text-primary-400"
            >
              +976 6003-4140
            </a>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-surface-400">Хаяг</h3>
            <p class="mt-2 text-surface-300">
              Улаанбаатар хот, Монгол Улс
            </p>
          </div>

          <div>
            <h3 class="text-xs font-semibold uppercase tracking-widest text-surface-400">
              Ажлын цаг
            </h3>
            <p class="mt-2 text-surface-300">
              Даваа - Баасан: 09:00 - 18:00
            </p>
          </div>
        </div>

        <!-- Form -->
        <div class="md:col-span-3" data-reveal data-reveal-delay="1">
          <div class="rounded-2xl border border-white/[0.08] bg-white/[0.02] p-8">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
