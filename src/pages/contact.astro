---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactForm from "@/components/ContactForm.svelte";
---

<BaseLayout title="Холбоо барих — orinux ARP">
  <section class="pt-32 pb-24">
    <div class="mx-auto max-w-7xl px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-bold md:text-5xl">Холбоо барих</h1>
        <p class="mt-4 text-lg text-surface-200">
          Демо авах, асуулт тавих, хамтран ажиллах — бидэнтэй холбогдоорой.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl gap-12 md:grid-cols-5">
        <!-- Contact Info -->
        <div class="space-y-8 md:col-span-2">
          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-200">И-мэйл</h3>
            <a
              href="mailto:info@orinux.space"
              class="mt-2 block text-lg transition-colors hover:text-primary-400"
            >
              info@orinux.space
            </a>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-200">Утас</h3>
            <a
              href="tel:+97699999999"
              class="mt-2 block text-lg transition-colors hover:text-primary-400"
            >
              +976 9999-9999
            </a>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-200">Хаяг</h3>
            <p class="mt-2 text-surface-200">
              Улаанбаатар хот, Монгол Улс
            </p>
          </div>

          <div>
            <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-200">
              Ажлын цаг
            </h3>
            <p class="mt-2 text-surface-200">
              Даваа - Баасан: 09:00 - 18:00
            </p>
          </div>
        </div>

        <!-- Form -->
        <div class="md:col-span-3">
          <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-8">
            <ContactForm client:visible />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
