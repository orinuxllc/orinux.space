---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Хуудас олдсонгүй">
  <section class="relative flex min-h-[80vh] items-center overflow-hidden">
    <div class="absolute inset-0 -z-10">
      <div class="absolute left-1/2 top-1/3 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-600/10 blur-[128px]"></div>
    </div>

    <div class="mx-auto max-w-7xl px-6 text-center">
      <div class="text-8xl font-bold tracking-tight text-gradient-accent md:text-9xl" data-reveal>
        404
      </div>
      <h1 class="mt-4 text-2xl font-bold tracking-tight md:text-3xl" data-reveal data-reveal-delay="1">
        Хуудас олдсонгүй
      </h1>
      <p class="mt-4 text-lg text-surface-300" data-reveal data-reveal-delay="2">
        Таны хайсан хуудас байхгүй эсвэл зөөгдсөн байна.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row" data-reveal data-reveal-delay="3">
        <a href="/" class="btn-primary">
          Нүүр хуудас
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
        </a>
        <a href="/contact" class="btn-secondary">
          Холбоо барих
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
