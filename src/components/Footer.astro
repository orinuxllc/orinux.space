---
const currentYear = new Date().getFullYear();

const footerLinks = {
  product: [
    { label: "Модулиуд", href: "/modules" },
    { label: "Үйлчилгээ", href: "/services" },
    { label: "Үнэ", href: "/pricing" },
  ],
  company: [
    { label: "Бидний тухай", href: "/about" },
    { label: "Холбоо барих", href: "/contact" },
  ],
  legal: [
    { label: "Нууцлалын бодлого", href: "#" },
    { label: "Үйлчилгээний нөхцөл", href: "#" },
  ],
};
---

<footer class="relative border-t border-white/[0.06] bg-surface-950">
  <!-- Gradient top border -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-500/40 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 py-16">
    <div class="grid gap-12 md:grid-cols-5">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="group inline-flex items-center gap-2.5">
          <div
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-accent-500 shadow-lg shadow-primary-500/20 transition-shadow group-hover:shadow-primary-500/40"
          >
            <span class="text-sm font-bold text-white">O</span>
          </div>
          <span class="text-lg font-bold tracking-tight">orinux</span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-surface-400">
          Agentic Resource Planning — AI Agent-ууд таны бизнес процессыг автомат удирдаж, хүнийг давтагдах ажлаас чөлөөлнө.
        </p>
        <div class="mt-6 flex items-center gap-3 text-sm text-surface-400">
          <svg class="h-4 w-4 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          info@orinux.space
        </div>
        <div class="mt-2 flex items-center gap-3 text-sm text-surface-400">
          <svg class="h-4 w-4 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          +976 6003-4140
        </div>
      </div>

      <!-- Product -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-surface-400">
          Бүтээгдэхүүн
        </h3>
        <ul class="space-y-3">
          {
            footerLinks.product.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-surface-400 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-surface-400">
          Компани
        </h3>
        <ul class="space-y-3">
          {
            footerLinks.company.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-surface-400 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-surface-400">
          Хууль
        </h3>
        <ul class="space-y-3">
          {
            footerLinks.legal.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-surface-400 transition-colors hover:text-white"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/[0.06] pt-8 md:flex-row"
    >
      <p class="text-sm text-surface-400">
        &copy; {currentYear} Orinux LLC. Бүх эрх хуулиар хамгаалагдсан.
      </p>
      <div class="flex items-center gap-5">
        <a
          href="#"
          class="text-surface-400 transition-all hover:text-white hover:scale-110"
          aria-label="Facebook"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
        </a>
        <a
          href="#"
          class="text-surface-400 transition-all hover:text-white hover:scale-110"
          aria-label="LinkedIn"
        >
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
