---
const navLinks = [
  { href: "/#features", label: "Давуу тал" },
  { href: "/#modules", label: "Модулиуд" },
  { href: "/services", label: "Үйлчилгээ" },
  { href: "/pricing", label: "Үнэ" },
  { href: "/about", label: "Бидний тухай" },
  { href: "/contact", label: "Холбоо барих" },
];

const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 z-50 w-full border-b border-white/[0.06] glass"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2.5">
      <div
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-primary-500 to-accent-500 shadow-lg shadow-primary-500/20 transition-shadow group-hover:shadow-primary-500/40"
      >
        <span class="text-sm font-bold text-white">O</span>
      </div>
      <span class="text-lg font-bold tracking-tight">orinux</span>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden items-center gap-7 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "nav-link text-sm transition-colors",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "text-white active"
                : "text-surface-300 hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="hidden items-center gap-4 md:flex">
      <a
        href="https://auth.orinux.space"
        class="text-sm text-surface-300 transition-colors hover:text-white"
      >
        Нэвтрэх
      </a>
      <a
        href="/contact"
        class="shine-on-hover rounded-lg bg-gradient-to-r from-primary-600 to-primary-500 px-4 py-2 text-sm font-medium shadow-lg shadow-primary-600/20 transition-all hover:shadow-primary-600/40"
      >
        Демо авах
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-surface-300 transition-colors hover:bg-white/10 hover:text-white md:hidden"
      aria-label="Цэс нээх"
    >
      <svg
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-white/[0.06] glass md:hidden"
    style="max-height:0;overflow:hidden;transition:max-height 0.3s ease"
  >
    <div class="space-y-1 px-6 py-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "block rounded-lg px-3 py-2.5 transition-colors",
              currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
                ? "bg-white/10 text-white font-medium"
                : "text-surface-300 hover:bg-white/[0.06] hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <div class="mt-4 flex flex-col gap-2 border-t border-white/[0.06] pt-4">
        <a
          href="https://auth.orinux.space"
          class="rounded-lg px-3 py-2.5 text-center text-surface-300 transition-colors hover:bg-white/[0.06]"
        >
          Нэвтрэх
        </a>
        <a
          href="/contact"
          class="rounded-lg bg-gradient-to-r from-primary-600 to-primary-500 px-3 py-2.5 text-center font-medium"
        >
          Демо авах
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    if (menu) {
      const isOpen = menu.style.maxHeight !== "0px" && menu.style.maxHeight !== "";
      menu.style.maxHeight = isOpen ? "0px" : menu.scrollHeight + "px";
      menu.classList.toggle("hidden", false);
      if (isOpen) setTimeout(() => menu.classList.add("hidden"), 300);
    }
  });
</script>
