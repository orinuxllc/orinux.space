---
import { features } from "@/data/features";

const iconPaths: Record<string, string> = {
  bot: "M12 8V4H8M12 8a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM4 12a8 8 0 0 0 16 0M9 17v1m6-1v1M2 8h2m16 0h2",
  zap: "M13 2L3 14h9l-1 8 10-12h-9l1-8",
  blocks: "M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z",
  "building-2": "M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18ZM6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2M10 6h4M10 10h4M10 14h4M10 18h4",
  wrench: "M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z",
  "map-pin": "M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0ZM12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z",
};
---

<section id="features" class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold md:text-4xl">Яагаад ARP?</h2>
      <p class="mt-4 text-lg text-surface-200">
        Бизнесийн бүх процессыг нэг платформд, AI-ийн хүчээр.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div class="group rounded-2xl border border-white/10 bg-white/[0.03] p-8 transition-all hover:border-primary-500/30 hover:bg-white/[0.06]">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary-500/10 text-primary-400 transition-colors group-hover:bg-primary-500/20">
              <svg
                class="h-6 w-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                viewBox="0 0 24 24"
              >
                <path d={iconPaths[feature.icon] || iconPaths["blocks"]} />
              </svg>
            </div>
            <h3 class="mt-5 text-lg font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-200">{feature.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
