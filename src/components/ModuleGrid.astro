---
import { modules, categories } from "@/data/modules";
---

<section id="modules" class="py-24 bg-white/[0.015]">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        <span class="text-gradient-accent">40+</span> модуль, нэг платформ
      </h2>
      <p class="mt-4 text-lg text-surface-300">
        Хэрэгтэй модулиа сонгоод шууд эхэл. Бүгдийг нь авах шаардлагагүй.
      </p>
    </div>

    {
      categories
        .filter((cat) => cat.id !== "platform")
        .map((cat) => {
          const catModules = modules.filter((m) => m.category === cat.id);
          const isIndustry = cat.id === "industry";
          return (
            <div class="mt-12" data-reveal>
              <div class="mb-6 flex items-center gap-3">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-surface-400">
                  {cat.name}
                </h3>
                <span class:list={[
                  "rounded-full px-2.5 py-0.5 text-xs font-medium",
                  isIndustry ? "bg-accent-500/10 text-accent-400" : "bg-primary-500/10 text-primary-400"
                ]}>
                  {catModules.length}
                </span>
              </div>
              <div class="grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
                {catModules.map((mod) => (
                  <div class="group flex items-center gap-3 rounded-xl border border-white/[0.06] bg-white/[0.02] px-4 py-3.5 hover-lift transition-all hover:border-primary-500/15 hover:bg-white/[0.04]">
                    <div class:list={[
                      "flex h-9 w-9 shrink-0 items-center justify-center rounded-lg text-xs font-bold",
                      isIndustry
                        ? "bg-gradient-to-br from-accent-500/15 to-primary-500/10 text-accent-400"
                        : "bg-gradient-to-br from-primary-500/15 to-accent-500/10 text-primary-400"
                    ]}>
                      {mod.nameEn.slice(0, 2).toUpperCase()}
                    </div>
                    <div class="min-w-0">
                      <div class="text-sm font-medium">{mod.name}</div>
                      <div class="text-xs text-surface-400 truncate">{mod.desc}</div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          );
        })
    }

    <div class="mt-12 text-center" data-reveal>
      <a href="/modules" class="btn-secondary text-sm">
        Бүх модулиуд үзэх
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
