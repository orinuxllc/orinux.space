---
import { stats } from "@/data/features";
---

<section class="relative overflow-hidden pt-32 pb-20">
  <!-- Background Gradient -->
  <div class="absolute inset-0 -z-10">
    <div
      class="absolute left-1/2 top-0 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-primary-600/20 blur-[128px]"
    >
    </div>
    <div
      class="absolute right-0 top-1/3 h-[400px] w-[400px] rounded-full bg-accent-600/15 blur-[96px]"
    >
    </div>
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <!-- Badge -->
    <div class="flex justify-center">
      <div
        class="inline-flex items-center gap-2 rounded-full border border-primary-500/30 bg-primary-500/10 px-4 py-1.5"
      >
        <span class="h-2 w-2 animate-pulse rounded-full bg-primary-400"></span>
        <span class="text-sm text-primary-300">Дараа үеийн ERP платформ</span>
      </div>
    </div>

    <!-- Heading -->
    <h1
      class="mx-auto mt-8 max-w-4xl text-center text-5xl font-bold leading-tight tracking-tight md:text-7xl"
    >
      <span
        class="bg-gradient-to-r from-white via-white to-surface-200 bg-clip-text text-transparent"
      >
        Agentic Resource
      </span>
      <br />
      <span
        class="bg-gradient-to-r from-primary-400 to-accent-400 bg-clip-text text-transparent"
      >
        Planning
      </span>
    </h1>

    <!-- Subtitle -->
    <p
      class="mx-auto mt-6 max-w-2xl text-center text-lg leading-relaxed text-surface-200 md:text-xl"
    >
      AI Agent-ууд таны бизнес процессыг автомат удирддаг.
      <br class="hidden md:block" />
      Хүн зөвхөн шийдвэр батална. <strong class="text-white">40+ модуль, 21 tool.</strong>
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-xl bg-primary-600 px-8 py-3.5 font-medium transition-all hover:bg-primary-500 hover:shadow-lg hover:shadow-primary-600/25"
      >
        Демо авах
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <a
        href="/#modules"
        class="inline-flex items-center gap-2 rounded-xl border border-white/20 px-8 py-3.5 font-medium transition-all hover:border-white/40 hover:bg-white/5"
      >
        Модулиуд үзэх
      </a>
    </div>

    <!-- Stats -->
    <div
      class="mx-auto mt-20 grid max-w-3xl grid-cols-2 gap-8 border-t border-white/10 pt-10 md:grid-cols-4"
    >
      {
        stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-white">{stat.value}</div>
            <div class="mt-1 text-sm text-surface-200">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
