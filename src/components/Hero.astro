---
import { stats } from "@/data/features";
---

<section class="relative overflow-hidden pt-32 pb-24 md:pt-40 md:pb-32">
  <!-- Background Effects -->
  <div class="absolute inset-0 -z-10">
    <!-- Grid pattern -->
    <div class="absolute inset-0 bg-grid-pattern opacity-40 animate-grid-move"></div>
    <!-- Primary glow -->
    <div
      class="absolute left-1/2 top-0 h-[600px] w-[900px] -translate-x-1/2 rounded-full bg-primary-600/15 blur-[128px] animate-float-slow"
    ></div>
    <!-- Accent glow -->
    <div
      class="absolute right-0 top-1/3 h-[400px] w-[400px] rounded-full bg-accent-600/10 blur-[96px] animate-float"
    ></div>
    <!-- Bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-surface-950 to-transparent"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6">
    <!-- Badge -->
    <div class="flex justify-center" data-reveal>
      <div
        class="inline-flex items-center gap-2 rounded-full border border-primary-500/20 bg-primary-500/[0.08] px-5 py-2 shadow-lg shadow-primary-500/10"
      >
        <span class="h-2 w-2 animate-pulse rounded-full bg-primary-400"></span>
        <span class="text-sm font-medium text-primary-300">Дараа үеийн ERP платформ</span>
      </div>
    </div>

    <!-- Heading -->
    <h1
      class="mx-auto mt-8 max-w-5xl text-center text-5xl font-bold leading-[1.08] tracking-tight md:text-7xl lg:text-8xl"
      data-reveal data-reveal-delay="1"
    >
      <span class="text-gradient-primary">
        Agentic Resource
      </span>
      <br />
      <span class="text-gradient-flow">
        Planning
      </span>
    </h1>

    <!-- Subtitle -->
    <p
      class="mx-auto mt-7 max-w-2xl text-center text-lg leading-relaxed text-surface-300 md:text-xl"
      data-reveal data-reveal-delay="2"
    >
      AI Agent-ууд таны бизнес процессыг автомат удирддаг.
      <br class="hidden md:block" />
      Хүн зөвхөн шийдвэр батална. <strong class="text-white font-semibold">40+ модуль, 21 tool.</strong>
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row" data-reveal data-reveal-delay="3">
      <a href="/contact" class="btn-primary">
        Демо авах
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <a href="/#modules" class="btn-secondary">
        Модулиуд үзэх
      </a>
    </div>

    <!-- Stats -->
    <div
      class="mx-auto mt-20 grid max-w-3xl grid-cols-2 gap-8 border-t border-white/[0.06] pt-10 md:grid-cols-4"
      data-reveal data-reveal-delay="4"
    >
      {
        stats.map((stat) => (
          <div class="text-center">
            <div
              class="text-3xl font-bold text-white md:text-4xl"
              data-count={stat.value.replace("+", "").replace("/", "")}
              data-suffix={stat.value.includes("+") ? "+" : stat.value.includes("/") ? "/7" : ""}
            >
              {stat.value}
            </div>
            <div class="mt-1.5 text-sm text-surface-400">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <!-- Scroll Indicator -->
    <div class="mt-16 flex justify-center" data-reveal data-reveal-delay="5">
      <div class="flex flex-col items-center gap-2 text-surface-400">
        <span class="text-xs uppercase tracking-widest">Доош гүйлгэ</span>
        <svg class="h-5 w-5 animate-bounce-down" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </div>
</section>
