---
import { plans } from "@/data/pricing";
---

<section id="pricing" class="py-24 bg-white/[0.02]">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold md:text-4xl">Энгийн, ил тод үнэ</h2>
      <p class="mt-4 text-lg text-surface-200">
        Бизнесийнхээ хэмжээнд тохирсон тарифыг сонго. Хэзээ ч шилжиж болно.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        plans.map((plan) => (
          <div
            class:list={[
              "relative rounded-2xl border p-8 transition-all",
              plan.popular
                ? "border-primary-500/50 bg-primary-500/5 shadow-lg shadow-primary-500/10"
                : "border-white/10 bg-white/[0.03]",
            ]}
          >
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-primary-600 px-4 py-1 text-xs font-medium">
                Түгээмэл
              </div>
            )}

            <h3 class="text-xl font-semibold">{plan.name}</h3>
            <p class="mt-1 text-sm text-surface-200">{plan.desc}</p>

            <div class="mt-6">
              {plan.period ? (
                <>
                  <span class="text-4xl font-bold">{plan.price}</span>
                  <span class="text-surface-200">₮/{plan.period}</span>
                </>
              ) : (
                <span class="text-4xl font-bold">{plan.price}</span>
              )}
            </div>

            <a
              href="/contact"
              class:list={[
                "mt-8 block rounded-xl py-3 text-center font-medium transition-all",
                plan.popular
                  ? "bg-primary-600 hover:bg-primary-500"
                  : "border border-white/20 hover:border-white/40 hover:bg-white/5",
              ]}
            >
              {plan.cta}
            </a>

            <ul class="mt-8 space-y-3">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-primary-400"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-surface-200">{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
