---
import { plans } from "@/data/pricing";
---

<section id="pricing" class="py-24 bg-white/[0.015]">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Энгийн, ил тод үнэ</h2>
      <p class="mt-4 text-lg text-surface-300">
        Бизнесийнхээ хэмжээнд тохирсон тарифыг сонго. Хэзээ ч шилжиж болно.
      </p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        plans.map((plan, i) => (
          <div
            class:list={[
              "relative rounded-2xl border p-8 transition-all hover-lift",
              plan.popular
                ? "border-primary-500/30 bg-gradient-to-b from-primary-500/[0.08] to-transparent shadow-xl shadow-primary-500/10 animate-border-glow"
                : "border-white/[0.08] bg-white/[0.02] hover:border-white/15",
            ]}
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-primary-600 to-primary-500 px-4 py-1 text-xs font-semibold shadow-lg shadow-primary-600/30">
                Түгээмэл
              </div>
            )}

            <h3 class="text-xl font-semibold tracking-tight">{plan.name}</h3>
            <p class="mt-1 text-sm text-surface-400">{plan.desc}</p>

            <div class="mt-6">
              {plan.period ? (
                <>
                  <span class="text-4xl font-bold tracking-tight">{plan.price}</span>
                  <span class="text-surface-400">₮/{plan.period}</span>
                </>
              ) : (
                <span class="text-4xl font-bold tracking-tight">{plan.price}</span>
              )}
            </div>

            <a
              href="/contact"
              class:list={[
                "mt-8 block rounded-xl py-3 text-center font-medium transition-all",
                plan.popular
                  ? "btn-primary justify-center"
                  : "border border-white/15 hover:border-white/30 hover:bg-white/[0.04]",
              ]}
            >
              {plan.cta}
            </a>

            <ul class="mt-8 space-y-3">
              {plan.features.map((f) => (
                <li class="flex items-start gap-3 text-sm">
                  <svg
                    class="mt-0.5 h-4 w-4 shrink-0 text-primary-400"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-surface-300">{f}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
