---
const comparisons = [
  {
    erp: "Хүн бүх зүйлийг гараар оруулна",
    arp: "AI Agent автомат оруулна, хүн батлана",
  },
  {
    erp: "Тогтмол workflow дүрэм",
    arp: "AI шийдвэр + Event-driven автоматжуулалт",
  },
  {
    erp: "Нэг том suite худалдаж авах",
    arp: "Хэрэгтэй модулиа л сонгоно",
  },
  {
    erp: "Нэг байгууллагад суулгац",
    arp: "Multi-tenant SaaS — хаанаас ч хандана",
  },
  {
    erp: "Хүнд, удаан тохиргоо",
    arp: "AI тохируулна, минутын дотор эхэлнэ",
  },
];
---

<section class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
        ERP хуучирсан.
        <span class="text-gradient-accent">ARP</span> шинэ стандарт.
      </h2>
      <p class="mt-4 text-lg text-surface-300">
        Уламжлалт ERP системүүд хүнээс хамааралтай. ARP нь AI Agent-ууд ажлыг гүйцэтгэж, хүн
        зөвхөн стратеги, шийдвэрт анхаарна.
      </p>
    </div>

    <div class="mx-auto mt-16 max-w-4xl overflow-hidden rounded-2xl border border-white/[0.08] bg-white/[0.02]" data-reveal data-reveal-delay="1">
      <!-- Header -->
      <div class="grid grid-cols-2 bg-white/[0.04]">
        <div class="border-r border-white/[0.06] px-6 py-4">
          <span class="text-sm font-medium text-surface-400">Хуучин ERP</span>
        </div>
        <div class="px-6 py-4">
          <span class="text-sm font-semibold text-primary-400">ARP (orinux)</span>
        </div>
      </div>

      {
        comparisons.map((row, i) => (
          <div
            class:list={[
              "grid grid-cols-2 transition-colors hover:bg-white/[0.03]",
              i < comparisons.length - 1 && "border-b border-white/[0.04]",
            ]}
          >
            <div class="flex items-center gap-3 border-r border-white/[0.06] px-6 py-4 text-sm text-surface-400">
              <svg class="h-4 w-4 shrink-0 text-red-400/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              {row.erp}
            </div>
            <div class="flex items-center gap-3 px-6 py-4 text-sm text-white">
              <svg class="h-4 w-4 shrink-0 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {row.arp}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
