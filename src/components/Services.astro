---
import { services } from "@/data/services";

const topServices = services.slice(0, 3);
---

<section id="services" class="py-24">
  <div class="mx-auto max-w-7xl px-6">
    <div class="mx-auto max-w-3xl text-center" data-reveal>
      <div class="inline-flex items-center gap-2 rounded-full border border-accent-500/20 bg-accent-500/[0.08] px-5 py-2 shadow-lg shadow-accent-500/5">
        <span class="h-2 w-2 animate-pulse rounded-full bg-accent-400"></span>
        <span class="text-sm font-medium text-accent-300">Мэргэжлийн үйлчилгээ</span>
      </div>
      <h2 class="mt-6 text-3xl font-bold tracking-tight md:text-4xl">
        AI Agent & RAG Тохируулалт
      </h2>
      <p class="mt-4 text-lg text-surface-300">
        Танай байгууллагын үйл ажиллагааг AI-ээр автоматж��улж,
        мэдлэгийн санд суурилсан ухаалаг систем бүтээж өгнө.
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3">
      {
        topServices.map((service, i) => (
          <div
            class="group relative rounded-2xl border border-white/[0.08] bg-white/[0.02] p-8 hover-lift transition-all hover:border-accent-500/20 hover:bg-white/[0.04]"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            {/* Tag */}
            <div class="absolute right-6 top-6">
              <span class="rounded-full bg-accent-500/10 px-3 py-1 text-xs font-medium text-accent-400">
                {service.tag}
              </span>
            </div>

            {/* Icon */}
            <div class="flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br from-primary-500/15 to-accent-500/15 text-primary-400 transition-all group-hover:from-primary-500/25 group-hover:to-accent-500/25 group-hover:scale-110 group-hover:shadow-lg group-hover:shadow-primary-500/10">
              <svg
                class="h-7 w-7"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                viewBox="0 0 24 24"
              >
                <path d={service.icon} />
              </svg>
            </div>

            <h3 class="mt-5 text-xl font-semibold tracking-tight">{service.name}</h3>
            <p class="mt-2 text-sm leading-relaxed text-surface-300">{service.desc}</p>

            <ul class="mt-5 space-y-2">
              {service.features.slice(0, 4).map((f) => (
                <li class="flex items-center gap-2 text-sm text-surface-300">
                  <svg class="h-4 w-4 shrink-0 text-primary-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-12 text-center" data-reveal>
      <a href="/services" class="btn-secondary text-sm">
        Бүх үйлчилгээ үзэх
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
